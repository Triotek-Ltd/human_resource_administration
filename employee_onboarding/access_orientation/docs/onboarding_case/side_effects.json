{
  "confirm": [
    {
      "type": "create_record",
      "target_doc": "employee_record",
      "values": {
        "title": {
          "$template": "Employee Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "EMPLOYEE_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ]
}
