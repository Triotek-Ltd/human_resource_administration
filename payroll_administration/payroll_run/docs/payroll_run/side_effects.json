{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "post": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "posted"
      }
    },
    {
      "type": "create_record",
      "target_doc": "payroll_transaction",
      "values": {
        "title": {
          "$template": "Payroll Transaction for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "PAYROLL_TRANSACTION-{reference_no|id}"
        }
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "attendance_record",
      "values": {
        "title": {
          "$template": "Attendance Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "ATTENDANCE_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
